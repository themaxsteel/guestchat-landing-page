---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'GuestChat — Satu inbox untuk semua percakapan tamu hotel',
  description = 'WhatsApp, email, dan live chat website dalam satu layar — dibantu AI Agent yang membalas otomatis dan dashboard reputasi dari semua OTA.',
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/webp" href="/assets/logos/guestchat.webp" />
    <link rel="apple-touch-icon" href="/assets/logos/guestchat.webp" />

    <!-- Self-hosted Plus Jakarta Sans: preload above-the-fold weights -->
    <link rel="preload" href="/fonts/plus-jakarta-sans-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/plus-jakarta-sans-800.woff2" as="font" type="font/woff2" crossorigin />

    <title>{title}</title>
  </head>
  <body class="bg-white font-sans text-zinc-900 antialiased">
    <slot />
  </body>
</html>
