---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
import { waHref } from '../data/site';

// Kanal yang bermuara ke satu inbox.
const channels = [
  { logo: '/assets/logos/whatsapp.webp', label: 'WhatsApp' },
  { logo: '/assets/logos/gmail.webp', label: 'Email' },
  { logo: '/assets/logos/instagram.webp', label: 'Instagram DM' },
  { logo: '/assets/logos/facebook.webp', label: 'Facebook' },
  { logo: '/assets/logos/telegram.webp', label: 'Telegram' },
  { logo: '/assets/logos/line.webp', label: 'LINE' },
  { logo: '/assets/logos/booking.webp', label: 'Booking.com' },
  { logo: '/assets/logos/airbnb.webp', label: 'Airbnb' },
  { logo: '/assets/logos/traveloka.webp', label: 'Traveloka' },
  { logo: '/assets/logos/tiket.webp', label: 'Tiket.com' },
];

// Fitur mendalam dari inbox terpadu.
const features = [
  {
    title: 'Satu antrean real-time',
    body: 'WhatsApp, email, live chat website, hingga pesan dari OTA mengalir ke satu daftar. Tidak ada lagi lompat antar aplikasi atau tab yang terlupakan.',
  },
  {
    title: 'Konteks tamu menempel otomatis',
    body: 'Status Upcoming, In House, atau Past Stay beserta nomor folio muncul di setiap percakapan — staf paham siapa yang sedang mereka layani sebelum membalas.',
  },
  {
    title: 'Tidak ada yang terlewat',
    body: 'Indikator belum terbaca dan urutan prioritas otomatis menjaga setiap pesan tetap tertangani, bahkan saat percakapan menumpuk.',
  },
  {
    title: 'Satu tamu, satu riwayat',
    body: 'Percakapan dari kanal berbeda dirangkai jadi satu utas per tamu. Riwayat menginap dan pesan sebelumnya selalu tersedia saat dibutuhkan.',
  },
  {
    title: 'Kerja tim tanpa tabrakan',
    body: 'Tetapkan percakapan ke staf tertentu dan tinggalkan catatan internal, agar tidak ada dua orang membalas tamu yang sama.',
  },
  {
    title: 'Dibantu AI kapan pun',
    body: 'AI Agent yang paham kamar, tarif, dan kebijakan hotel Anda bisa membalas otomatis di inbox yang sama — Anda tinggal mengambil alih saat perlu.',
  },
];

// Cara kerja singkat.
const steps = [
  {
    n: '01',
    title: 'Hubungkan kanal Anda',
    body: 'Sambungkan WhatsApp, email, akun OTA, dan widget website ke GuestChat dalam beberapa langkah.',
  },
  {
    n: '02',
    title: 'Pesan masuk dengan konteks',
    body: 'Setiap pesan tampil di satu inbox lengkap dengan data reservasi dan status menginap tamu.',
  },
  {
    n: '03',
    title: 'Balas manual atau lewat AI',
    body: 'Jawab sendiri, tugaskan ke staf, atau biarkan AI Agent membalas — semua dari layar yang sama.',
  },
];
---

<Layout
  title="Inbox Terpadu — GuestChat"
  description="Satu inbox real-time untuk WhatsApp, email, live chat website, dan pesan OTA. Setiap percakapan menempel pada data reservasi tamu, dibantu AI Agent."
>
  <Nav />

  <main class="overflow-x-hidden">
    <!-- ===== Hero detail ===== -->
    <section class="relative overflow-hidden border-b border-[#f0f0f2] bg-mist">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute left-1/2 top-0 h-[460px] w-[460px] -translate-x-1/2 rounded-full opacity-60 blur-3xl"
        style="background:radial-gradient(circle,rgba(163,217,119,0.30) 0%,rgba(163,217,119,0) 70%);"
      >
      </div>

      <div class="relative z-[2] mx-auto max-w-[1120px] px-5 py-16 sm:px-7 md:py-24">
        <nav class="mb-7 flex items-center gap-2 text-[13px] font-medium text-zinc-500" aria-label="Breadcrumb">
          <a href="/" class="no-underline transition-colors hover:text-brand">Beranda</a>
          <span aria-hidden="true">/</span>
          <span class="text-zinc-700">Inbox Terpadu</span>
        </nav>

        <div class="grid grid-cols-1 items-center gap-14 lg:grid-cols-2 lg:gap-[58px]">
          <div>
            <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Inbox Terpadu</span>
            <h1 class="mt-3.5 text-[34px] font-extrabold leading-[1.08] tracking-[-0.03em] text-balance sm:text-[44px]">
              Semua percakapan tamu, dalam satu layar
            </h1>
            <p class="mb-8 mt-[18px] max-w-[520px] text-[17px] leading-[1.65] text-zinc-600">
              WhatsApp, email, live chat website, hingga pesan dari OTA mengalir ke satu antrean real-time. Setiap
              percakapan menempel pada data reservasi tamu — jadi staf paham konteksnya sebelum membalas.
            </p>
            <div class="flex flex-wrap gap-3.5">
              <a
                href="/#demo"
                class="group inline-flex items-center gap-[9px] rounded-xl bg-brand px-[26px] py-[15px] text-[16px] font-bold text-white no-underline shadow-[0_8px_22px_rgba(59,122,46,0.28)] transition-all hover:-translate-y-0.5 hover:bg-brand-dark"
              >
                Coba Gratis
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" class="transition-transform group-hover:translate-x-0.5"
                  ><path d="M5 12h14M13 6l6 6-6 6" stroke="#fff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path></svg
                >
              </a>
              <a
                href={waHref}
                class="inline-flex items-center gap-[9px] rounded-xl border-[1.5px] border-[#d9dcdd] bg-white/80 px-6 py-[15px] text-[16px] font-semibold text-zinc-900 no-underline backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:border-brand hover:text-brand"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                  ><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2Z" stroke="#25aa5a" stroke-width="2" stroke-linejoin="round"></path></svg
                >
                Hubungi via WhatsApp
              </a>
            </div>
          </div>

          <div class="relative motion-safe:animate-floaty">
            <img
              src="/assets/unified-inbox.png"
              alt="Inbox terpadu GuestChat — WhatsApp, email, dan live chat dalam satu daftar percakapan"
              width="1200"
              height="900"
              loading="eager"
              decoding="async"
              class="w-full rounded-2xl border border-black/5 shadow-[0_20px_50px_rgba(15,26,12,0.12)]"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Kanal ===== -->
    <section class="border-b border-[#f0f0f2] bg-white">
      <div class="mx-auto max-w-[1120px] px-5 py-[72px] sm:px-7">
        <div class="mx-auto max-w-[640px] text-center">
          <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Semua Kanal</span>
          <h2 class="mt-3.5 text-[26px] font-extrabold leading-[1.15] tracking-[-0.02em] text-balance sm:text-[32px]">
            Satu tempat untuk setiap kanal tamu
          </h2>
          <p class="mx-auto mt-4 max-w-[520px] text-[16px] leading-[1.6] text-zinc-600">
            Tamu menghubungi Anda dari mana saja. GuestChat menyatukannya jadi satu daftar, tanpa perlu membuka banyak
            aplikasi.
          </p>
        </div>

        <div class="mt-12 grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-5">
          {
            channels.map((c) => (
              <div class="flex items-center gap-3 rounded-xl border border-[#ececee] bg-white px-4 py-3.5">
                <img src={c.logo} alt="" width="28" height="28" class="h-7 w-7 flex-none" loading="lazy" />
                <span class="text-[14px] font-semibold text-zinc-800">{c.label}</span>
              </div>
            ))
          }
          <div class="flex items-center gap-3 rounded-xl border border-[#ececee] bg-white px-4 py-3.5">
            <span class="flex h-7 w-7 flex-none items-center justify-center rounded-lg bg-brand-50">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                ><path d="M4 5h16v11H9l-4 3v-3H4V5Z" stroke="var(--color-brand)" stroke-width="2" stroke-linejoin="round"></path></svg
              >
            </span>
            <span class="text-[14px] font-semibold text-zinc-800">Live Chat</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== Fitur mendalam ===== -->
    <section class="border-b border-[#f0f0f2] bg-zinc-50">
      <div class="mx-auto max-w-[1120px] px-5 py-[80px] sm:px-7">
        <div class="max-w-[600px]">
          <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Cara Kerjanya</span>
          <h2 class="mt-3.5 text-[26px] font-extrabold leading-[1.15] tracking-[-0.02em] text-balance sm:text-[32px]">
            Dirancang agar tidak ada pesan yang terlewat
          </h2>
        </div>

        <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {
            features.map((f) => (
              <div class="rounded-2xl border border-[#ececee] bg-white p-6">
                <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                    <path d="M20 6 9 17l-5-5" stroke="var(--color-brand)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <h3 class="mt-4 text-[17px] font-bold text-zinc-900">{f.title}</h3>
                <p class="mt-2 text-[14.5px] leading-[1.6] text-zinc-600">{f.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===== Langkah ===== -->
    <section class="border-b border-[#f0f0f2] bg-white">
      <div class="mx-auto max-w-[1120px] px-5 py-[80px] sm:px-7">
        <div class="mx-auto max-w-[600px] text-center">
          <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Mulai Cepat</span>
          <h2 class="mt-3.5 text-[26px] font-extrabold leading-[1.15] tracking-[-0.02em] text-balance sm:text-[32px]">
            Tiga langkah sampai inbox pertama Anda hidup
          </h2>
        </div>

        <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
          {
            steps.map((s) => (
              <div class="relative">
                <div class="font-mono text-[28px] font-extrabold text-brand-200">{s.n}</div>
                <h3 class="mt-2 text-[18px] font-bold text-zinc-900">{s.title}</h3>
                <p class="mt-2 text-[15px] leading-[1.6] text-zinc-600">{s.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===== Fitur lain ===== -->
    <section class="bg-zinc-50">
      <div class="mx-auto max-w-[1120px] px-5 py-16 sm:px-7">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div>
            <h2 class="text-[20px] font-bold text-zinc-900">Jelajahi fitur lainnya</h2>
            <p class="mt-1 text-[15px] text-zinc-600">Inbox terpadu hanya satu bagian dari GuestChat.</p>
          </div>
          <div class="flex flex-wrap gap-2.5">
            <a href="/#widget" class="rounded-lg border border-[#d9dcdd] bg-white px-4 py-2.5 text-[14px] font-semibold text-zinc-800 no-underline transition-colors hover:border-brand hover:text-brand">Chat Widget</a>
            <a href="/#ai" class="rounded-lg border border-[#d9dcdd] bg-white px-4 py-2.5 text-[14px] font-semibold text-zinc-800 no-underline transition-colors hover:border-brand hover:text-brand">AI Agent</a>
            <a href="/#reputasi" class="rounded-lg border border-[#d9dcdd] bg-white px-4 py-2.5 text-[14px] font-semibold text-zinc-800 no-underline transition-colors hover:border-brand hover:text-brand">Reputasi</a>
          </div>
        </div>
      </div>
    </section>

    <FinalCta />
  </main>

  <Footer />
</Layout>
