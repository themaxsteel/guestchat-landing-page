---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/HeroCentered.astro';
import LogoBar from '../components/LogoBar.astro';
import ProblemThreeActs from '../components/ProblemThreeActs.astro';
import UnifiedInbox from '../components/UnifiedInbox.astro';
import ChatWidget from '../components/ChatWidget.astro';
import AiAgent from '../components/AiAgent.astro';
import Reputation from '../components/Reputation.astro';
import Mobile from '../components/Mobile.astro';
import Testimonials from '../components/Testimonials.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';
---

<Layout>
  <Nav />
  <main class="min-h-screen overflow-x-hidden">
    <Hero />
    {site.showLogoBar && <LogoBar />}
    <ProblemThreeActs />
    <UnifiedInbox />
    <ChatWidget />
    <AiAgent />
    <Reputation />
    <Mobile />
    {site.showTestimonials && <Testimonials />}
    <Faq />
    <FinalCta />
  </main>
  <Footer />
</Layout>
