<style is:global>
  #crm .gc-tab.is-active {
    color: var(--color-brand);
    box-shadow: inset 0 -2px 0 0 var(--color-brand);
  }
  #crm .gc-panel {
    display: none;
  }
  #crm .gc-panel.is-active {
    display: block;
    animation: gcPanelIn 0.34s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes gcPanelIn {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #crm .gc-panel.is-active {
      animation: none;
    }
  }
</style>

<script>
  const section = document.getElementById('crm');
  if (section) {
    const tabs = Array.from(section.querySelectorAll('[data-gc-tab]'));
    const panels = Array.from(section.querySelectorAll('[data-gc-panel]'));
    const order = tabs.map((t) => t.getAttribute('data-gc-tab'));
    const mq = window.matchMedia('(prefers-reduced-motion: reduce)');

    let idx = 0;
    let timer = 0;
    let running = false;
    let inView = false;

    function show(i) {
      idx = (i + order.length) % order.length;
      const id = order[idx];
      tabs.forEach((t) => {
        const active = t.getAttribute('data-gc-tab') === id;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      panels.forEach((p) => {
        p.classList.toggle('is-active', p.getAttribute('data-gc-panel') === id);
      });
    }

    function clearTimer() {
      if (timer) {
        window.clearTimeout(timer);
        timer = 0;
      }
    }

    function schedule() {
      clearTimer();
      timer = window.setTimeout(() => {
        show(idx + 1);
        schedule();
      }, 3600);
    }

    function start() {
      if (running || mq.matches) return;
      running = true;
      schedule();
    }

    function stop() {
      running = false;
      clearTimer();
    }

    // manual tab clicks: switch immediately, then keep auto-rotating from there
    tabs.forEach((t, i) => {
      t.addEventListener('click', () => {
        show(i);
        if (running) schedule();
      });
    });

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          inView = e.isIntersecting;
          if (inView && !document.hidden) start();
          else stop();
        });
      },
      { threshold: 0.35 }
    );
    io.observe(section);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop();
      else if (inView) start();
    });

    if (mq.addEventListener) {
      mq.addEventListener('change', () => {
        if (mq.matches) stop();
        else if (inView) start();
      });
    }
  }
</script>
