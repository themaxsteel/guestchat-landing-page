];

const tabs = [
  {
    id: 'profile',
    label: 'Profile',
    icon: '<circle cx="12" cy="8.5" r="3.2" stroke="currentColor" stroke-width="1.8"/><path d="M5.5 19a6.5 6.5 0 0 1 13 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
  },
  {
    id: 'reservation',
    label: 'Reservation',
    icon: '<rect x="3.5" y="6" width="17" height="12" rx="2.2" stroke="currentColor" stroke-width="1.8"/><path d="M3.5 10h17" stroke="currentColor" stroke-width="1.8"/>',
  },
  {
    id: 'history',
    label: 'History',
    icon: '<rect x="4" y="5" width="16" height="15" rx="2.2" stroke="currentColor" stroke-width="1.8"/><path d="M4 9h16M8 3.5v3M16 3.5v3M9.5 14l1.8 1.8L15 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
  },
  {
    id: 'memories',
    label: 'Memories',
    icon: '<rect x="4" y="5" width="16" height="14" rx="2.2" stroke="currentColor" stroke-width="1.8"/><circle cx="9" cy="10" r="1.6" stroke="currentColor" stroke-width="1.6"/><path d="m5 17 4-4 3.5 3.5L16 13l3 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
