---
const faqs = [
  {
    q: 'Setup AI-nya rumit, ya?',
    a: 'Tidak. Anda cukup menghubungkan sumber informasi hotel — data kamar, tarif, kebijakan, dan layanan — lalu AI langsung siap menjawab. Tanpa keahlian teknis, dan tim kami mendampingi proses awalnya.',
  },
  {
    q: 'Bagaimana kalau AI membalas ngawur?',
    a: 'AI Agent hanya menjawab dari data hotel Anda, bukan mengarang. Untuk pertanyaan di luar pengetahuannya, percakapan otomatis diteruskan ke staf. Anda juga bisa memakai mode draf: AI menyiapkan jawaban, staf menyetujui sebelum terkirim.',
  },
  {
    q: 'Bisa coba dulu sebelum berlangganan?',
    a: 'Bisa. Kami sediakan akun demo agar Anda langsung mencoba seluruh aplikasi apa adanya — tanpa kartu kredit, tanpa komitmen.',
  },
  {
    q: 'Apakah data tamu saya aman?',
    a: 'Ya. GuestChat dilengkapi login 2FA, penyamaran nomor & email tamu, serta kontrol akses berbasis peran (Admin, Supervisor, Agent) agar setiap staf hanya melihat yang perlu.',
  },
  {
    q: 'Kanal apa saja yang bisa digabung?',
    a: 'WhatsApp, email, dan live chat website dalam satu inbox. Ulasan dari Booking.com, Agoda, Traveloka, Tiket.com, Expedia, Trip.com, dan Airbnb juga terkumpul di dashboard reputasi.',
  },
  {
    q: 'Perlu aplikasi khusus untuk tim saya?',
    a: 'Tidak. GuestChat berjalan di web, plus aplikasi native Android & iOS yang tersinkron real-time — jadi tim Anda bisa membalas tamu dari mana saja.',
  },
];
---

<section id="faq" class="border-y border-[#f0f0f2] bg-zinc-50">
  <div class="mx-auto max-w-[760px] px-5 py-[84px] sm:px-7">
    <div class="mx-auto mb-12 max-w-[600px] text-center">
      <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">FAQ</span>
      <h2 class="mt-3.5 text-[28px] font-extrabold leading-[1.15] tracking-[-0.025em] sm:text-[36px]">
        Pertanyaan yang sering diajukan
      </h2>
    </div>

    <div class="flex flex-col gap-3">
      {
        faqs.map((f) => (
          <details class="faq group rounded-2xl border border-[#ececee] bg-white px-[22px] open:border-brand-200">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-[18px] text-[16px] font-bold text-zinc-900 [&::-webkit-details-marker]:hidden">
              {f.q}
              <span class="flex h-6 w-6 flex-none items-center justify-center rounded-full bg-brand-50 text-brand transition-transform duration-200 group-open:rotate-45">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
                </svg>
              </span>
            </summary>
            <p class="m-0 pb-[20px] pr-8 text-[15px] leading-[1.6] text-zinc-600">{f.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
