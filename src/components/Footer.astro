---
import { site, waHref, year } from '../data/site';

const produk = [
  { href: '/inbox', label: 'Inbox Terpadu' },
  { href: '/widget', label: 'Chat Widget' },
  { href: '/#ai', label: 'AI Agent' },
  { href: '/#mobile', label: 'Aplikasi Mobile' },
  { href: '/#reputasi', label: 'Reputation' },
  { href: '/integrasi', label: 'Integrasi' },
];

const perusahaan = [
  { href: '#', label: 'Tentang Kami' },
  { href: '#', label: 'Blog' },
  { href: '#', label: 'Karier' },
  { href: '#', label: 'Kebijakan Privasi' },
];
---

<footer class="bg-forest-950 text-[#c3ccbb]">
  <div class="mx-auto max-w-[1120px] px-5 pb-8 pt-16 sm:px-7">
    <div class="grid grid-cols-2 gap-10 md:grid-cols-4 lg:grid-cols-[1.6fr_1fr_1fr_1fr]">
      <div class="col-span-2 md:col-span-1">
        <a href="/#top" class="mb-4 flex items-center gap-2.5 no-underline">
          <img src="/assets/logos/guestchat.webp" alt="Logo GuestChat" width="36" height="36" class="h-9 w-9" />
          <span class="text-[19px] font-extrabold text-white">GuestChat</span>
        </a>
        <p class="mb-5 max-w-[300px] text-sm leading-[1.6] text-[#8f9985]">
          Satu inbox untuk semua percakapan tamu hotel Anda. WhatsApp, email, dan live chat — dibantu AI.
        </p>
        <div class="flex gap-2.5">
          <a href="#" aria-label="Instagram" class="flex h-[34px] w-[34px] items-center justify-center rounded-[9px] bg-forest-800 no-underline">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
              ><rect x="3.5" y="3.5" width="17" height="17" rx="5" stroke="#a3d977" stroke-width="1.8"></rect><circle
                cx="12"
                cy="12"
                r="3.6"
                stroke="#a3d977"
                stroke-width="1.8"></circle><circle cx="17" cy="7" r="1" fill="#a3d977"></circle></svg
            >
          </a>
          <a href="#" aria-label="LinkedIn" class="flex h-[34px] w-[34px] items-center justify-center rounded-[9px] bg-forest-800 no-underline">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
              ><rect x="3.5" y="3.5" width="17" height="17" rx="3" stroke="#a3d977" stroke-width="1.8"></rect><path
                d="M8 10.5V16M8 7.6v.01M11.7 16v-3.2a1.8 1.8 0 0 1 3.6 0V16"
                stroke="#a3d977"
                stroke-width="1.8"
                stroke-linecap="round"></path></svg
            >
          </a>
          <a href={waHref} aria-label="WhatsApp" class="flex h-[34px] w-[34px] items-center justify-center rounded-[9px] bg-forest-800 no-underline">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
              ><path d="M12 2.5a9.5 9.5 0 0 0-8.1 14.4L2.5 21.5l4.8-1.3A9.5 9.5 0 1 0 12 2.5Z" stroke="#a3d977" stroke-width="1.8" stroke-linejoin="round"
              ></path></svg
            >
          </a>
        </div>
      </div>

      <div>
        <div class="mb-4 text-sm font-bold text-white">Produk</div>
        <div class="flex flex-col gap-[11px]">
          {produk.map((l) => <a href={l.href} class="text-sm text-[#8f9985] no-underline hover:text-brand-lime">{l.label}</a>)}
        </div>
      </div>

      <div>
        <div class="mb-4 text-sm font-bold text-white">Perusahaan</div>
        <div class="flex flex-col gap-[11px]">
          {perusahaan.map((l) => <a href={l.href} class="text-sm text-[#8f9985] no-underline hover:text-brand-lime">{l.label}</a>)}
        </div>
      </div>

      <div>
        <div class="mb-4 text-sm font-bold text-white">Kontak</div>
        <div class="flex flex-col gap-[11px]">
          <a href={`mailto:${site.email}`} class="text-sm text-[#8f9985] no-underline hover:text-brand-lime">{site.email}</a>
          <a href={waHref} class="text-sm text-[#8f9985] no-underline hover:text-brand-lime">{site.phoneDisplay}</a>
          <span class="text-sm leading-[1.5] text-[#8f9985]">{site.location}</span>
        </div>
      </div>
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-between gap-3 border-t border-forest-800 pt-6">
      <span class="text-[13px] text-[#6f7a65]">© {year} GuestChat. Seluruh hak cipta dilindungi.</span>
      <span class="font-mono text-xs text-[#6f7a65]">Web · Android · iOS</span>
    </div>
  </div>
</footer>
