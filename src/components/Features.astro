---
const features = [
  {
    title: 'Inbox Terpadu',
    body: 'WhatsApp, email, dan live chat dalam satu layar real-time — dengan indikator terbaca dan prioritas otomatis.',
    icon: '<path d="M4 6.5A2.5 2.5 0 0 1 6.5 4h11A2.5 2.5 0 0 1 20 6.5v7A2.5 2.5 0 0 1 17.5 16H9l-4 4V6.5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>',
  },
  {
    title: 'AI Agent',
    body: 'Membalas otomatis dengan pengetahuan lengkap soal kamar, tarif, kebijakan, dan layanan hotel Anda — dengan eskalasi ke staf saat perlu.',
    icon: '<rect x="5" y="8" width="14" height="10" rx="3" stroke="currentColor" stroke-width="2"/><path d="M12 3.5V8M8.5 13h.01M15.5 13h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
  },
  {
    title: 'Reputation Management',
    body: 'Kumpulkan ulasan Booking, Agoda, Traveloka & lainnya, analisis sentimen, dan balas langsung sebelum jadi masalah.',
    icon: '<path d="M12 3.5l2.6 5.3 5.9.9-4.2 4.1 1 5.8L12 17l-5.3 2.6 1-5.8L3.5 9.7l5.9-.9L12 3.5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>',
  },
  {
    title: 'Kolaborasi Tim',
    body: 'Penugasan, status, catatan internal, dan penanda prioritas — seluruh tim selaras walau hanya beranggota beberapa orang.',
    icon: '<circle cx="9" cy="8" r="3" stroke="currentColor" stroke-width="2"/><path d="M3.5 19a5.5 5.5 0 0 1 11 0M16 6.2a3 3 0 0 1 0 5.6M18 19a5.2 5.2 0 0 0-2.6-4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
  },
  {
    title: 'Multi-Properti',
    body: 'Punya lebih dari satu properti? Kelola semuanya dari satu akun, berpindah lokasi sekali klik dengan data terpisah.',
    icon: '<path d="M4 20V7l6-3 4 2 6-3v13M10 4v16M14 6v14" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>',
  },
  {
    title: 'Chat Widget',
    body: 'Tempel satu potong kode di website hotel Anda — widget chat langsung tampil, bisa dikustom sesuai brand, dibalas AI 24/7, dan semua pesan mengalir ke satu inbox GuestChat.',
    icon: '<path d="M5 4.5h14a2 2 0 0 1 2 2V14a2 2 0 0 1-2 2h-6.5L8 19.5V16H5a2 2 0 0 1-2-2V6.5a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M8 10h.01M12 10h.01M16 10h.01" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>',
  },
];
---

<section id="fitur" class="bg-white">
  <div class="mx-auto max-w-[1120px] px-5 py-[84px] sm:px-7">
    <div class="mx-auto mb-[52px] max-w-[640px] text-center">
      <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Fitur Utama</span>
      <h2 class="mt-3.5 text-[28px] font-extrabold leading-[1.15] tracking-[-0.025em] sm:text-[36px]">
        Kekuatan tim besar, untuk tim sekecil apa pun
      </h2>
      <p class="mt-3.5 text-[17px] leading-[1.6] text-zinc-600">
        Satu platform yang dirancang untuk staf hospitality bertempo tinggi — semua yang Anda butuhkan, tanpa berantakan.
      </p>
    </div>

    <div
      id="feature-showcase"
      class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,420px)_minmax(0,1fr)] lg:gap-10"
    >
      <!-- LEFT: feature list -->
      <div class="flex flex-col gap-1.5" role="tablist" aria-label="Daftar fitur">
        {
          features.map((f, i) => (
            <button
              type="button"
              class="feat-item group relative w-full rounded-2xl border border-transparent px-[18px] py-4 text-left transition-colors"
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`feat-panel-${i}`}
              data-index={i}
            >
              <div class="flex items-start gap-3.5">
                <span class="feat-icon mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-50 text-brand transition-colors">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" set:html={f.icon} />
                </span>
                <div class="min-w-0">
                  <h3 class="text-[16px] font-bold tracking-[-0.01em] text-zinc-900">{f.title}</h3>
                  <p class="feat-body m-0 mt-1 text-[13.5px] leading-[1.55] text-zinc-500">{f.body}</p>
                </div>
              </div>
              <span class="feat-bar pointer-events-none absolute inset-x-[18px] bottom-2 hidden h-[3px] overflow-hidden rounded-full bg-brand-100 lg:block">
                <span class="feat-fill block h-full w-0 rounded-full bg-brand" />
              </span>
            </button>
          ))
        }
      </div>

      <!-- RIGHT: showcase stage -->
      <div class="feat-stage relative overflow-hidden rounded-[22px] border border-[#ececee] bg-gradient-to-br from-mist/70 to-white p-4 sm:p-6">
        <span class="pointer-events-none absolute -right-16 -top-16 h-52 w-52 rounded-full bg-brand-lime/20 blur-3xl"></span>

        <!-- 0: Inbox Terpadu -->
        <div id="feat-panel-0" class="panel" role="tabpanel" data-index="0">
          <div class="mock">
            <div class="mock-head">
              <span class="mock-dot"></span><span class="mock-dot"></span><span class="mock-dot"></span>
              <span class="ml-2 text-[11px] font-medium text-zinc-400">Inbox — Semua Kanal</span>
            </div>
            <div class="ib-list">
              <!-- Budi Santoso -->
              <div class="ib-row anim" style="--d:0.30s">
                <div class="ib-ava">
                  <img class="ib-photo" src="https://i.pravatar.cc/96?img=12" alt="Budi Santoso" loading="lazy" />
                  <span class="ib-src"><img src="/assets/logos/booking.webp" alt="Booking.com" loading="lazy" /></span>
                </div>
                <div class="ib-main">
                  <div class="ib-top"><b class="ib-name">Budi Santoso</b><span class="ib-time ib-time-new">Kemarin</span></div>
                  <p class="ib-prev"><span>Ini perjalanan bulan madu, kami mau kamar lantai satu ya</span></p>
                  <div class="ib-tags">
                    <span class="ib-tag ib-up"><svg class="ib-ic" viewBox="0 0 24 24" fill="none"><rect x="3.5" y="5" width="17" height="15" rx="2.5" stroke="currentColor" stroke-width="2" /><path d="M3.5 9.5h17M8 3v4M16 3v4" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>Upcoming<i class="ib-div"></i>Folio: 11927</span>
                  </div>
                </div>
                <span class="ib-unread">2</span>
              </div>

              <!-- Siti Rahmawati -->
              <div class="ib-row anim" style="--d:0.48s">
                <div class="ib-ava">
                  <img class="ib-photo" src="https://i.pravatar.cc/96?img=45" alt="Siti Rahmawati" loading="lazy" />
                  <span class="ib-src"><img src="/assets/logos/traveloka.webp" alt="Traveloka" loading="lazy" /></span>
                </div>
                <div class="ib-main">
                  <div class="ib-top"><b class="ib-name">Siti Rahmawati</b><span class="ib-time">Rabu</span></div>
                  <p class="ib-prev"><svg class="ib-check" viewBox="0 0 24 24" fill="none"><path d="M4 12.5l5 5 11-11" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" /></svg><span>Check-in online sudah dikonfirmasi. Terima kasih!</span></p>
                  <div class="ib-tags">
                    <span class="ib-tag ib-inhouse"><svg class="ib-ic" viewBox="0 0 24 24" fill="none"><path d="M4 11l8-6 8 6M6 10v9h12v-9" stroke="currentColor" stroke-width="2" stroke-linejoin="round" /></svg>In House<i class="ib-div"></i>Folio: 11712</span>
                  </div>
                </div>
              </div>

              <!-- Agus Setiawan -->
              <div class="ib-row anim" style="--d:0.66s">
                <div class="ib-ava">
                  <img class="ib-photo" src="https://i.pravatar.cc/96?img=33" alt="Agus Setiawan" loading="lazy" />
                  <span class="ib-src"><img src="/assets/logos/airbnb.webp" alt="Airbnb" loading="lazy" /></span>
                </div>
                <div class="ib-main">
                  <div class="ib-top"><b class="ib-name">Agus Setiawan</b><span class="ib-time">Rabu</span></div>
                  <p class="ib-prev"><svg class="ib-check" viewBox="0 0 24 24" fill="none"><path d="M4 12.5l5 5 11-11" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" /></svg><span>Halo, apakah bisa pindah ke kamar lantai bawah?</span></p>
                  <div class="ib-tags">
                    <span class="ib-tag ib-past"><svg class="ib-ic" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="2" /><path d="M12 7.5V12l3 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>Past Stay<i class="ib-div"></i>Folio: 11919</span>
                  </div>
                </div>
              </div>

              <!-- Dewi Lestari -->
              <div class="ib-row anim" style="--d:0.84s">
                <div class="ib-ava">
                  <img class="ib-photo" src="https://i.pravatar.cc/96?img=47" alt="Dewi Lestari" loading="lazy" />
                  <span class="ib-src"><img src="/assets/logos/tiket.webp" alt="Tiket.com" loading="lazy" /></span>
                </div>
                <div class="ib-main">
                  <div class="ib-top"><b class="ib-name">Dewi Lestari</b><span class="ib-time">Rabu</span></div>
                  <p class="ib-prev"><span>Apakah bisa early check-in besok pagi?</span></p>
                  <div class="ib-tags">
                    <span class="ib-tag ib-up"><svg class="ib-ic" viewBox="0 0 24 24" fill="none"><rect x="3.5" y="5" width="17" height="15" rx="2.5" stroke="currentColor" stroke-width="2" /><path d="M3.5 9.5h17M8 3v4M16 3v4" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>Upcoming<i class="ib-div"></i>Folio: 11924</span>
                  </div>
                </div>
              </div>

              <!-- Rizki Pratama -->
              <div class="ib-row anim" style="--d:1.02s">
                <div class="ib-ava">
                  <img class="ib-photo" src="https://i.pravatar.cc/96?img=68" alt="Rizki Pratama" loading="lazy" />
                  <span class="ib-src"><img src="/assets/logos/expedia.webp" alt="Expedia" loading="lazy" /></span>
                </div>
                <div class="ib-main">
                  <div class="ib-top"><b class="ib-name">Rizki Pratama</b><span class="ib-time">Kemarin</span></div>
                  <p class="ib-prev"><span>Terima kasih, pelayanannya sangat memuaskan!</span></p>
                  <div class="ib-tags">
                    <span class="ib-tag ib-inhouse"><svg class="ib-ic" viewBox="0 0 24 24" fill="none"><path d="M4 11l8-6 8 6M6 10v9h12v-9" stroke="currentColor" stroke-width="2" stroke-linejoin="round" /></svg>In House<i class="ib-div"></i>Folio: 11705</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 1: AI Agent -->
        <div id="feat-panel-1" class="panel" role="tabpanel" data-index="1">
          <div class="mock">
            <div class="mock-head">
              <span class="mock-dot"></span><span class="mock-dot"></span><span class="mock-dot"></span>
              <span class="ml-2 text-[11px] font-medium text-zinc-400">Percakapan — AI Agent aktif</span>
            </div>
            <div class="flex flex-col gap-2.5 p-4">
              <div class="bubble bubble-in anim" style="--d:0.3s">
                Halo, saya Budi — ini perjalanan bulan madu kami. Bisa dapat kamar lantai satu ya?
              </div>

              <!-- AI menautkan data reservasi sebelum menjawab -->
              <div class="ai-ctx anim self-end" style="--d:0.7s">
                <div class="ai-ctx-head">
                  <span class="ai-ctx-spark"><svg viewBox="0 0 24 24" fill="none"><path d="M12 3l1.9 5.1L19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9L12 3Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg></span>
                  <span>Membaca data tamu &amp; hotel…</span>
                </div>
                <div class="ai-ctx-rows">
                  <span class="ai-ctx-item"><b>Budi Santoso</b> · Folio 11927</span>
                  <span class="ai-ctx-item">Deluxe King · 2 malam</span>
                  <span class="ai-ctx-item">Booking.com · Upcoming</span>
                  <span class="ai-ctx-item">Kamar lantai 1 tersedia</span>
                </div>
              </div>

              <div class="anim flex items-center gap-2 self-end" style="--d:1.5s">
                <span class="ai-tag">AI Agent</span><span class="text-[10px] text-zinc-400">mengetik…</span>
              </div>
              <div class="bubble bubble-out anim" style="--d:1.9s">
                <span class="typewriter">Selamat atas bulan madunya, Pak Budi! Reservasi Deluxe King (2 malam) sudah kami catat — kami sediakan kamar lantai 1 menghadap taman untuk Anda.</span>
              </div>
              <div class="anim self-end text-[9.5px] leading-tight text-zinc-400" style="--d:3.4s">
                Berdasarkan: reservasi tamu · ketersediaan kamar · kebijakan hotel
              </div>
              <div class="anim flex gap-2 self-end" style="--d:3.7s">
                <span class="chip">✓ Kirim otomatis</span><span class="chip">✎ Edit dulu</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 2: Reputation Management -->
        <div id="feat-panel-2" class="panel" role="tabpanel" data-index="2">
          <div class="mock flex flex-col p-4">
            <div class="anim flex items-center justify-between gap-3" style="--d:0.3s">
              <div class="flex items-baseline gap-2">
                <span class="text-[30px] font-extrabold leading-none text-zinc-900">4.7</span>
                <div>
                  <div class="text-[12px] leading-none text-status-warn">★★★★★</div>
                  <div class="mt-1 text-[10px] text-zinc-400">1.284 ulasan</div>
                </div>
              </div>
              <div class="flex max-w-[54%] flex-wrap justify-end gap-1.5">
                <span class="ota">Booking 4.8</span>
                <span class="ota">Agoda 4.6</span>
                <span class="ota">Traveloka 4.7</span>
                <span class="ota">Google 4.9</span>
              </div>
            </div>

            <div class="anim mt-3 space-y-1.5" style="--d:0.5s">
              <div class="senti"><span>Positif</span><i class="track"><b class="fill-pos" style="--w:78%"></b></i></div>
              <div class="senti"><span>Netral</span><i class="track"><b class="fill-neu" style="--w:16%"></b></i></div>
              <div class="senti"><span>Negatif</span><i class="track"><b class="fill-neg" style="--w:6%"></b></i></div>
            </div>

            <div class="anim mt-3 flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-wide text-zinc-400" style="--d:0.85s">
              <span class="h-1.5 w-1.5 rounded-full bg-brand"></span>Kata kunci dari ulasan
            </div>
            <div class="wc anim mt-1.5 flex-1" style="--d:1s">
              <span class="wc-word wc-lg wc-pos">ramah</span>
              <span class="wc-word wc-sm wc-neg">berisik</span>
              <span class="wc-word wc-xl wc-pos">nyaman</span>
              <span class="wc-word wc-sm wc-neu">standar</span>
              <span class="wc-word wc-lg wc-pos">pelayanan</span>
              <span class="wc-word wc-xs wc-neg">kamar #7</span>
              <span class="wc-word wc-xl wc-pos">bersih</span>
              <span class="wc-word wc-xs wc-pos wc-hide-sm">cozy</span>
              <span class="wc-word wc-lg wc-pos">rekomendasi</span>
              <span class="wc-word wc-sm wc-neu">oke</span>
              <span class="wc-word wc-md wc-pos">sarapan enak</span>
              <span class="wc-word wc-xs wc-neg">wifi lambat</span>
              <span class="wc-word wc-md wc-pos">bagus</span>
              <span class="wc-word wc-md wc-pos">tenang</span>
              <span class="wc-word wc-xs wc-neu wc-hide-sm">lumayan</span>
              <span class="wc-word wc-md wc-pos">strategis</span>
              <span class="wc-word wc-sm wc-pos">staf ramah</span>
              <span class="wc-word wc-md wc-pos">memuaskan</span>
              <span class="wc-word wc-xs wc-neg wc-hide-sm">parkir sempit</span>
              <span class="wc-word wc-sm wc-pos">cepat respons</span>
              <span class="wc-word wc-sm wc-pos wc-hide-sm">worth it</span>
              <span class="wc-word wc-xs wc-neg wc-hide-sm">ac kurang</span>
              <span class="wc-word wc-sm wc-pos">view indah</span>
              <span class="wc-word wc-xs wc-pos wc-hide-sm">happy</span>
            </div>
          </div>
        </div>

        <!-- 3: Kolaborasi Tim -->
        <div id="feat-panel-3" class="panel" role="tabpanel" data-index="3">
          <div class="mock p-4">
            <div class="flex items-center justify-between">
              <b class="text-[13px]">Tiket #4821 — Permintaan late check-out</b>
              <span class="status-pill anim" style="--d:1.4s">Resolved</span>
            </div>
            <div class="anim mt-3 flex items-center gap-2" style="--d:0.4s">
              <span class="text-[11px] text-zinc-500">Ditugaskan ke</span>
              <span class="ava" style="--c:#3b7a2e">DW</span>
              <b class="text-[12px]">Dewi W.</b>
              <span class="text-[10px] text-zinc-400">· Supervisor</span>
            </div>
            <div class="anim mt-3 rounded-xl border border-dashed border-brand-200 bg-brand-50/60 p-2.5" style="--d:0.7s">
              <div class="text-[10px] font-semibold uppercase tracking-wide text-brand">Catatan internal</div>
              <p class="mt-1 text-[12px] leading-snug text-zinc-600">Tamu VIP, sudah 3x menginap. ACC late check-out s/d 14.00.</p>
            </div>
            <div class="mt-3 flex gap-2">
              <span class="tagp anim" style="--d:0.95s;--c:#d9534f">● Prioritas Tinggi</span>
              <span class="tagp anim" style="--d:1.1s;--c:#3b7a2e">● VIP</span>
            </div>
          </div>
        </div>

        <!-- 4: Multi-Properti -->
        <div id="feat-panel-4" class="panel" role="tabpanel" data-index="4">
          <div class="mock p-4">
            <div class="text-[10px] font-semibold uppercase tracking-wide text-zinc-400">Beralih properti</div>
            <div class="mt-2 flex flex-col gap-1.5">
              <div class="prop anim is-current" style="--d:0.4s">
                <span class="ava" style="--c:#3b7a2e">GV</span>
                <div class="flex-1"><b class="text-[12.5px]">Green Valley Resort</b><div class="text-[10px] text-zinc-400">Bandung · 84 kamar</div></div>
                <span class="check">✓</span>
              </div>
              <div class="prop anim" style="--d:0.6s">
                <span class="ava" style="--c:#2c5c22">SB</span>
                <div class="flex-1"><b class="text-[12.5px]">Seaside Boutique</b><div class="text-[10px] text-zinc-400">Bali · 42 kamar</div></div>
                <span class="pill-count">6</span>
              </div>
              <div class="prop anim" style="--d:0.8s">
                <span class="ava" style="--c:#22331a">UH</span>
                <div class="flex-1"><b class="text-[12.5px]">Urban Heights Hotel</b><div class="text-[10px] text-zinc-400">Jakarta · 156 kamar</div></div>
                <span class="pill-count">12</span>
              </div>
            </div>
            <div class="anim mt-3 grid grid-cols-3 gap-2" style="--d:1s">
              <div class="stat"><b>98%</b><span>Response</span></div>
              <div class="stat"><b>2m</b><span>Avg. balas</span></div>
              <div class="stat"><b>4.7★</b><span>Reputasi</span></div>
            </div>
          </div>
        </div>

        <!-- 5: Chat Widget -->
        <div id="feat-panel-5" class="panel" role="tabpanel" data-index="5">
          <div class="mock cw-root">
            <!-- backdrop: website hotel -->
            <div class="cw-site">
              <div class="cw-bar">
                <span class="cw-dot"></span><span class="cw-dot"></span><span class="cw-dot"></span>
                <span class="cw-url">greenvalleyresort.com</span>
              </div>
              <div class="cw-page">
                <div class="cw-nav"><b>Green Valley Resort</b><span class="cw-nav-links">Kamar · Fasilitas · Kontak</span></div>
                <div class="cw-hero">
                  <div class="cw-hero-t">Menginap tenang di tengah kebun teh Bandung</div>
                  <span class="cw-hero-btn">Cek ketersediaan</span>
                </div>
                <div class="cw-cards"><span class="cw-card"></span><span class="cw-card"></span><span class="cw-card"></span></div>
              </div>
            </div>

            <!-- pesan dari widget masuk ke GuestChat -->
            <div class="cw-inbox anim" style="--d:2.7s">
              <span class="cw-inbox-logo">GC</span>
              <div class="cw-inbox-meta"><b>GuestChat · Inbox</b><span>Pesan baru dari widget web</span></div>
              <span class="cw-inbox-badge">1</span>
            </div>

            <!-- chat widget di pojok website -->
            <div class="cw-widget anim" style="--d:0.4s">
              <div class="cw-whead">
                <span class="cw-wava">GV</span>
                <div class="cw-wmeta"><b>Front Desk</b><span><i class="cw-online"></i>Online · dibalas AI</span></div>
                <span class="cw-wx">×</span>
              </div>
              <div class="cw-wbody">
                <div class="cw-greet anim" style="--d:0.8s">Hai! Ada yang bisa kami bantu?</div>
                <div class="cw-b cw-b-in anim" style="--d:1.3s">Halo, ada kamar untuk 20–22 Juni?</div>
                <div class="cw-b cw-b-out anim" style="--d:1.9s">Masih tersedia — mau kami bantu reservasinya?</div>
              </div>
              <div class="cw-winput anim" style="--d:2.3s">
                <span>Ketik pesan…</span>
                <span class="cw-send">→</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ---------- left list active state ---------- */
  .feat-item[aria-selected='true'] {
    background: #fff;
    border-color: var(--color-brand-200);
    box-shadow: 0 14px 34px -22px rgba(59, 122, 46, 0.5);
