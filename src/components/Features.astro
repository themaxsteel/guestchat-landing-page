<script>
  const root = document.getElementById('feature-showcase');
  if (root) {
    const items = Array.from(root.querySelectorAll<HTMLButtonElement>('.feat-item'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('.panel'));
    const DURATION = 5200;
    let active = 0;
    let paused = false;
    let start = performance.now();
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function render(i: number) {
      items.forEach((el, idx) => el.setAttribute('aria-selected', idx === i ? 'true' : 'false'));
      panels.forEach((el, idx) => el.classList.toggle('is-active', idx === i));
      // reset all fills, the active one is driven by the RAF loop
      items.forEach((el) => {
        const fill = el.querySelector<HTMLElement>('.feat-fill');
        if (fill) fill.style.width = '0%';
      });
    }

    function go(i: number, resetTimer = true) {
      active = (i + panels.length) % panels.length;
      if (resetTimer) start = performance.now();
      render(active);
    }

    function loop(now: number) {
      if (!paused) {
        const elapsed = now - start;
        const fill = items[active]?.querySelector<HTMLElement>('.feat-fill');
        if (fill) fill.style.width = Math.min(100, (elapsed / DURATION) * 100) + '%';
        if (elapsed >= DURATION) go(active + 1);
      }
      requestAnimationFrame(loop);
    }

    items.forEach((el, idx) => {
      el.addEventListener('click', () => go(idx));
    });

    // pause on hover / focus so users can read
    ['mouseenter', 'focusin'].forEach((ev) => root.addEventListener(ev, () => (paused = true)));
    ['mouseleave', 'focusout'].forEach((ev) =>
      root.addEventListener(ev, () => {
        paused = false;
        start = performance.now(); // restart the current slide's clock cleanly
      })
    );

    render(0);
    if (!reduce) requestAnimationFrame(loop);
  }
</script>
