---
const without = [
  'Pesan tersebar di banyak aplikasi — satu terlewat, satu booking hilang.',
  'Staf mengetik jawaban yang sama berulang kali, sepanjang hari.',
  'Ulasan buruk di OTA baru ketahuan setelah tamu pergi.',
  'Di luar jam kerja, pertanyaan tamu menggantung tanpa jawaban.',
];

const withGc = [
  'Semua kanal dalam satu inbox — tidak ada percakapan yang terlewat.',
  'AI Agent yang paham hotel Anda menjawab otomatis dalam hitungan detik.',
  'Dashboard reputasi memantau semua ulasan OTA secara real-time.',
  'Tamu tetap terlayani 24 jam, bahkan saat tim Anda beristirahat.',
];
---

<section class="border-b border-[#f0f0f2] bg-zinc-50">
  <div class="mx-auto max-w-[1120px] px-5 py-20 sm:px-7">
    <div class="mx-auto mb-12 max-w-[620px] text-center">
      <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Masalahnya</span>
      <h2 class="mt-3.5 text-[28px] font-extrabold leading-[1.15] tracking-[-0.025em] sm:text-[36px]">
        Tim Anda kecil. Pesan tamu di mana-mana.
      </h2>
      <p class="mt-3.5 text-[17px] leading-[1.6] text-zinc-600">
        WhatsApp pribadi, email, chat website — staf lompat antar aplikasi dan konteks hilang. Satu pesan terlewat bisa
        berarti satu booking batal atau satu ulasan bintang satu.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-[22px] md:grid-cols-2">
      <!-- Without -->
      <div class="rounded-2xl border border-[#eeecec] bg-white p-7">
        <div class="mb-[18px] text-[15px] font-bold text-zinc-500">Tanpa GuestChat</div>
        <div class="flex flex-col gap-3.5">
          {
            without.map((text) => (
              <div class="flex items-start gap-[11px]">
                <span class="mt-px flex h-5 w-5 flex-none items-center justify-center rounded-full bg-[#fbe6e6] text-[13px] font-bold text-[#c0392b]">
                  ✕
                </span>
                <span class="text-[14.5px] leading-[1.5] text-zinc-600">{text}</span>
              </div>
            ))
          }
        </div>
      </div>

      <!-- With -->
      <div class="rounded-2xl border-[1.5px] border-brand-200 bg-white p-7 shadow-[0_12px_30px_-18px_rgba(59,122,46,0.4)]">
        <div class="mb-[18px] text-[15px] font-bold text-brand">Dengan GuestChat</div>
        <div class="flex flex-col gap-3.5">
          {
            withGc.map((text) => (
              <div class="flex items-start gap-[11px]">
                <span class="mt-px flex h-5 w-5 flex-none items-center justify-center rounded-full bg-[#e3f2d5] text-[11px] font-bold text-brand">
                  ✓
                </span>
                <span class="text-[14.5px] leading-[1.5] text-zinc-700">{text}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
