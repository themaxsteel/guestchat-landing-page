---
const inbox = [
  { name: 'Sarah W.', msg: 'Kamar suite untuk 3 malam?', avatar: '#dce9cd', badge: '2' },
  { name: 'M. Kurniawan', msg: 'Terima kasih!', avatar: '#dbe6f5', badge: null },
  { name: 'Dina Pratiwi', msg: 'Bisa early check-in?', avatar: '#f5dede', badge: '3' },
];

const perks = [
  {
    icon: '<path d="M20 11a8 8 0 0 0-14.2-4.6M4 5v4h4M4 13a8 8 0 0 0 14.2 4.6M20 19v-4h-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
    title: 'Sinkron real-time',
    body: 'Sama di semua perangkat.',
  },
  {
    icon: '<path d="M6 9a6 6 0 0 1 12 0c0 5 2 6 2 6H4s2-1 2-6Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M10 20a2 2 0 0 0 4 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
    title: 'Notifikasi push',
    body: 'Tak ada pesan terlewat.',
  },
  {
    icon: '<path d="M4 20V7l6-3 4 2 6-3v13M10 4v16M14 6v14" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>',
    title: 'Multi-properti',
    body: 'Berpindah lokasi cepat.',
  },
  {
    icon: '<rect x="5" y="10" width="14" height="10" rx="2.5" stroke="currentColor" stroke-width="2"/><path d="M8 10V7.5a4 4 0 0 1 8 0V10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
    title: 'Keamanan sama',
    body: '2FA & penyamaran data.',
  },
];
---

<section id="mobile" class="bg-white">
  <div class="mx-auto grid max-w-[1120px] grid-cols-1 items-center gap-14 px-5 py-[88px] sm:px-7 lg:grid-cols-[0.9fr_1.1fr] lg:gap-14">
    <!-- phone -->
    <div class="order-2 flex justify-center lg:order-1">
      <div class="h-[472px] w-[236px] animate-floaty rounded-[38px] bg-zinc-900 p-[11px] shadow-[0_32px_60px_-26px_rgba(24,24,27,0.5)]">
        <div class="relative h-full w-full overflow-hidden rounded-[29px] bg-[#f4f7ef]">
          <div class="absolute left-1/2 top-[9px] h-[19px] w-[82px] -translate-x-1/2 rounded-[11px] bg-zinc-900"></div>
          <div class="px-3.5 pt-[38px]">
            <div class="flex items-center justify-between">
              <span class="text-[16px] font-extrabold text-zinc-900">Inbox</span>
              <span class="rounded-lg bg-brand px-2 py-[3px] text-[10px] font-bold text-white">99+</span>
            </div>
            <div class="mt-3.5 flex flex-col gap-[9px]">
              {
                inbox.map((c) => (
                  <div class="flex items-center gap-[9px] rounded-xl bg-white p-[11px] shadow-[0_2px_8px_rgba(0,0,0,0.04)]">
                    <span class="h-[30px] w-[30px] flex-none rounded-full" style={`background:${c.avatar};`} />
                    <div class="min-w-0 flex-1">
                      <div class="text-[12px] font-bold">{c.name}</div>
                      <div class="overflow-hidden text-ellipsis whitespace-nowrap text-[10.5px] text-zinc-500">{c.msg}</div>
                    </div>
                    {c.badge && (
                      <span class="flex h-4 w-4 flex-none items-center justify-center rounded-lg bg-brand text-[9px] font-bold text-white">
                        {c.badge}
                      </span>
                    )}
                  </div>
                ))
              }
            </div>
            <div class="absolute inset-x-3.5 bottom-3.5 flex items-center justify-center gap-[7px] rounded-xl bg-brand p-[11px]">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                ><path d="M12 3v18M3 12h18" stroke="#fff" stroke-width="2.4" stroke-linecap="round"></path></svg
              >
              <span class="text-[12px] font-bold text-white">Percakapan Baru</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- copy -->
    <div class="order-1 lg:order-2">
      <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Android &amp; iOS</span>
      <h2 class="mt-3.5 text-[28px] font-extrabold leading-[1.14] tracking-[-0.025em] text-balance sm:text-[36px]">
        Layani tamu dari genggaman, di mana pun
      </h2>
      <p class="mb-7 mt-4 text-[17px] leading-[1.6] text-zinc-600">
        Aplikasi mobile native, tersinkronisasi penuh dengan versi web secara real-time. Inbox lengkap dalam genggaman,
        notifikasi push, dan keamanan 2FA yang sama.
      </p>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        {
          perks.map((p) => (
            <div class="flex items-start gap-2.5">
              <span class="mt-0.5 flex h-9 w-9 flex-none items-center justify-center rounded-xl bg-brand-50 text-brand">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" set:html={p.icon} />
              </span>
              <div>
                <div class="text-[14.5px] font-bold">{p.title}</div>
                <div class="text-[13px] leading-[1.45] text-zinc-500">{p.body}</div>
              </div>
            </div>
          ))
        }
      </div>
      <div class="mt-[30px] flex flex-wrap gap-3">
        <span class="inline-flex items-center gap-[9px] rounded-[11px] bg-zinc-900 px-[18px] py-[11px] text-sm font-semibold text-white">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="#fff"
            ><path
              d="M16.5 1.6c.1 1-.3 2-.9 2.7-.7.8-1.7 1.4-2.7 1.3-.1-1 .3-2 .9-2.7.7-.8 1.8-1.3 2.7-1.3ZM19 17.4c-.5 1.2-.8 1.7-1.4 2.8-.9 1.5-2.1 3.3-3.6 3.3-1.3 0-1.7-.9-3.5-.9s-2.2.8-3.5.9c-1.5.1-2.6-1.6-3.5-3.1C1.1 17-.3 11.6 1.7 8.6c.9-1.4 2.5-2.3 4-2.3 1.5 0 2.5.9 3.7.9 1.2 0 1.9-.9 3.7-.9 1.3 0 2.7.7 3.7 2-3.2 1.8-2.7 6.4.5 7.6Z"
            ></path></svg
          >
          App Store
        </span>
        <span class="inline-flex items-center gap-[9px] rounded-[11px] bg-zinc-900 px-[18px] py-[11px] text-sm font-semibold text-white">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"
            ><path
              d="M3.6 2.3 13.2 12 3.6 21.7c-.4-.2-.6-.6-.6-1.1V3.4c0-.5.2-.9.6-1.1ZM14.6 13.4l2.5 2.5-3.3 1.9-2.4-2.5 3.2-1.9ZM11.4 12l2.4-2.4 3.3 1.9-2.5 2.5-3.2-2ZM5.1 1.7l9.6 5.5-2.6 2.6L5.1 1.7Z"
            ></path></svg
          >
          Google Play
        </span>
      </div>
    </div>
  </div>
</section>
