---
import { waHref } from '../data/site';
---

<section id="demo" class="bg-white">
  <div class="mx-auto max-w-[1120px] px-5 py-[88px] sm:px-7">
    <div
      class="relative overflow-hidden rounded-3xl px-6 py-14 text-center sm:px-10 sm:py-16"
      style="background:linear-gradient(135deg,#3b7a2e 0%,#2c5c22 100%);"
    >
      <div class="absolute -right-10 -top-[60px] h-[220px] w-[220px] rounded-full bg-white/[0.06]"></div>
      <div class="absolute -bottom-20 -left-[30px] h-[240px] w-[240px] rounded-full bg-white/[0.05]"></div>
      <div class="relative">
        <h2 class="m-0 text-[30px] font-extrabold leading-[1.1] tracking-[-0.025em] text-balance text-white sm:text-[40px]">
          Siap membuat setiap tamu merasa didengar?
        </h2>
        <p class="mx-auto mb-[34px] mt-[18px] max-w-[520px] text-[18px] leading-[1.55] text-[#dcecd0]">
          Coba GuestChat gratis dengan akun demo — pakai langsung, tanpa kartu kredit. Atau ngobrol dulu dengan tim kami
          lewat WhatsApp.
        </p>
        <div class="flex flex-wrap justify-center gap-3.5">
          <a
            href="#top"
            class="inline-flex items-center gap-[9px] rounded-xl bg-white px-7 py-[15px] text-[16px] font-bold text-brand-dark no-underline shadow-[0_10px_24px_rgba(0,0,0,0.18)]"
            >Coba Gratis</a
          >
          <a
            href={waHref}
            class="inline-flex items-center gap-[9px] rounded-xl border-[1.5px] border-white/35 bg-white/[0.12] px-[26px] py-[15px] text-[16px] font-semibold text-white no-underline"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
              ><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2Z" stroke="#fff" stroke-width="2" stroke-linejoin="round"
              ></path></svg
            >
            Hubungi via WhatsApp
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
