---
import { otas } from '../data/logos';

const bars = [
  { label: 'Kebersihan', width: '91%', color: '#3b7a2e', tag: 'Excellent', tagColor: '#3b7a2e' },
  { label: 'Layanan', width: '84%', color: '#3b7a2e', tag: 'Excellent', tagColor: '#3b7a2e' },
  { label: 'Sarapan', width: '52%', color: '#e6a23c', tag: 'Perlu Perhatian', tagColor: '#b8860b' },
];
---

<section id="reputasi" class="border-y border-[#f0f0f2] bg-zinc-50">
  <div class="mx-auto grid max-w-[1120px] grid-cols-1 items-center gap-14 px-5 py-[84px] sm:px-7 lg:grid-cols-[1.1fr_1fr] lg:gap-[58px]">
    <!-- copy -->
    <div class="order-1 lg:order-2">
      <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Reputation Management</span>
      <h2 class="mt-3.5 text-[28px] font-extrabold leading-[1.14] tracking-[-0.025em] sm:text-[36px]">
        Pantau semua ulasan, sebelum berdampak buruk
      </h2>
      <p class="mb-[26px] mt-4 text-[17px] leading-[1.6] text-zinc-600">
        Kumpulkan ulasan dari Booking.com, Agoda, Tiket.com, Traveloka, Expedia, Trip.com, dan Airbnb dalam satu dashboard
        — lengkap dengan analisis sentimen, agar Anda menangani keluhan sebelum berubah jadi ulasan bintang satu.
      </p>
      <div class="flex flex-wrap gap-2">
        {
          otas.map((o) => (
            <span class="inline-flex items-center gap-2 rounded-lg border border-zinc-200 bg-white px-[13px] py-[7px] text-[13px] font-semibold text-zinc-700">
              <img src={o.src} alt={`Logo ${o.name}`} width="18" height="18" class="h-[18px] w-[18px] rounded object-contain" loading="lazy" />
              {o.name}
            </span>
          ))
        }
      </div>
    </div>

    <!-- dashboard card -->
    <div class="order-2 lg:order-1">
      <div class="rounded-2xl border border-[#e7e7ea] bg-white p-6 shadow-[0_22px_50px_-30px_rgba(24,24,27,0.3)]">
        <div class="mb-5 flex items-center gap-5">
          <div
            class="relative flex h-[104px] w-[104px] flex-none items-center justify-center rounded-full"
            style="background:conic-gradient(#3b7a2e 0 72%,#e6a23c 72% 88%,#d9534f 88% 100%);"
          >
            <div class="flex h-[70px] w-[70px] flex-col items-center justify-center rounded-full bg-white">
              <span class="text-[22px] font-extrabold leading-none text-zinc-900">72%</span>
              <span class="mt-0.5 text-[10px] text-zinc-500">positif</span>
            </div>
          </div>
          <div class="flex flex-1 flex-col gap-[9px]">
            <div class="flex items-center gap-2 text-[13px]">
              <span class="h-2.5 w-2.5 rounded-[3px] bg-brand"></span><span class="font-semibold text-zinc-700">Positif</span
              ><span class="ml-auto text-zinc-500">72%</span>
            </div>
            <div class="flex items-center gap-2 text-[13px]">
              <span class="h-2.5 w-2.5 rounded-[3px] bg-status-warn"></span><span class="font-semibold text-zinc-700">Netral</span
              ><span class="ml-auto text-zinc-500">16%</span>
            </div>
            <div class="flex items-center gap-2 text-[13px]">
              <span class="h-2.5 w-2.5 rounded-[3px] bg-status-bad"></span><span class="font-semibold text-zinc-700">Negatif</span
              ><span class="ml-auto text-zinc-500">12%</span>
            </div>
          </div>
        </div>
        <div class="flex flex-col gap-[11px] border-t border-[#f0f0f2] pt-4">
          {
            bars.map((b) => (
              <div class="flex items-center gap-2.5">
                <span class="w-[88px] text-[13px] text-zinc-700">{b.label}</span>
                <div class="h-[7px] flex-1 overflow-hidden rounded bg-[#f0f0f2]">
                  <div class="h-full" style={`width:${b.width};background:${b.color};`} />
                </div>
                <span class="text-[12px] font-bold" style={`color:${b.tagColor};`}>
                  {b.tag}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
