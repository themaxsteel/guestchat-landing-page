---
const points = [
  {
    title: 'Pasang sekali, langsung jalan',
    body: 'Tempel satu potong kode di website hotel Anda — tanpa setup teknis yang rumit.',
  },
  {
    title: 'Sesuai brand hotel Anda',
    body: 'Warna, nama, dan sapaan widget bisa dikustom agar menyatu dengan tampilan situs Anda.',
  },
  {
    title: 'Terhubung ke satu inbox',
    body: 'Pesan dari widget masuk ke inbox yang sama dengan kanal lain, dibalas AI kapan pun.',
  },
];
---

<section id="widget" class="reveal border-t border-[#f0f0f2] bg-zinc-50">
  <div class="mx-auto grid max-w-[1120px] grid-cols-1 items-center gap-14 px-5 py-[88px] sm:px-7 lg:grid-cols-2 lg:gap-[58px]">
    <!-- widget image -->
    <div class="relative lg:order-1">
      <img
        src="/assets/chat-widget.png"
        alt="Widget chat GuestChat di website hotel — percakapan tamu dibalas otomatis"
        width="1536"
        height="1024"
        loading="lazy"
        class="w-full"
      />
    </div>

    <div class="lg:order-2">
      <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Chat Widget</span>
      <h2 class="mt-3.5 text-[30px] font-extrabold leading-[1.12] tracking-[-0.025em] text-balance sm:text-[38px]">
        Ubah pengunjung website jadi percakapan
      </h2>
      <p class="mb-[30px] mt-[18px] text-[17px] leading-[1.65] text-zinc-600">
        Tempel satu potong kode di website hotel Anda dan widget chat langsung tampil. Bisa disesuaikan dengan brand,
        dibalas AI 24 jam, dan setiap pesan mengalir ke inbox GuestChat yang sama dengan kanal lainnya.
      </p>
      <div class="flex flex-col gap-4">
        {
          points.map((p) => (
            <div class="flex items-start gap-[13px]">
              <span class="flex h-[26px] w-[26px] flex-none items-center justify-center rounded-lg bg-brand-50">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                  <path d="M20 6 9 17l-5-5" stroke="var(--color-brand)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <div>
                <div class="text-[15.5px] font-bold text-zinc-900">{p.title}</div>
                <div class="mt-0.5 text-sm leading-[1.5] text-zinc-500">{p.body}</div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
