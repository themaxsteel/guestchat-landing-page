---
const points = [
  {
    title: 'Pasang sekali, langsung jalan',
    body: 'Tempel satu potong kode di website hotel Anda — tanpa setup teknis yang rumit.',
  },
  {
    title: 'Sesuai brand hotel Anda',
    body: 'Warna, nama, dan sapaan widget bisa dikustom agar menyatu dengan tampilan situs Anda.',
  },
  {
    title: 'Terhubung ke satu inbox',
    body: 'Pesan dari widget masuk ke inbox yang sama dengan kanal lain, dibalas AI kapan pun.',
  },
];
---

<section id="widget" class="reveal border-t border-[#f0f0f2] bg-zinc-50">
  <div class="mx-auto grid max-w-[1120px] grid-cols-1 items-center gap-14 px-5 py-[88px] sm:px-7 lg:grid-cols-2 lg:gap-[58px]">
    <!-- widget mock -->
    <div class="stage relative overflow-hidden rounded-[22px] border border-[#ececee] bg-gradient-to-br from-mist/70 to-white p-4 sm:p-6 lg:order-1">
      <span class="pointer-events-none absolute -right-16 -top-16 h-52 w-52 rounded-full bg-brand-lime/20 blur-3xl"></span>
      <div class="mock cw-root">
        <!-- backdrop: website hotel -->
        <div class="cw-site">
          <div class="cw-bar">
            <span class="cw-dot"></span><span class="cw-dot"></span><span class="cw-dot"></span>
            <span class="cw-url">greenvalleyresort.com</span>
          </div>
          <div class="cw-page">
            <div class="cw-nav"><b>Green Valley Resort</b><span class="cw-nav-links">Kamar · Fasilitas · Kontak</span></div>
            <div class="cw-hero">
              <div class="cw-hero-t">Menginap tenang di tengah kebun teh Bandung</div>
              <span class="cw-hero-btn">Cek ketersediaan</span>
            </div>
            <div class="cw-cards"><span class="cw-card"></span><span class="cw-card"></span><span class="cw-card"></span></div>
          </div>
        </div>

        <!-- pesan dari widget masuk ke GuestChat -->
        <div class="cw-inbox anim" style="--d:2.7s">
          <span class="cw-inbox-logo">GC</span>
          <div class="cw-inbox-meta"><b>GuestChat · Inbox</b><span>Pesan baru dari widget web</span></div>
          <span class="cw-inbox-badge">1</span>
        </div>

        <!-- chat widget di pojok website -->
        <div class="cw-widget anim" style="--d:0.4s">
          <div class="cw-whead">
            <span class="cw-wava">GV</span>
            <div class="cw-wmeta"><b>Front Desk</b><span><i class="cw-online"></i>Online · dibalas AI</span></div>
            <span class="cw-wx">×</span>
          </div>
          <div class="cw-wbody">
            <div class="cw-greet anim" style="--d:0.8s">Hai! Ada yang bisa kami bantu?</div>
            <div class="cw-b cw-b-in anim" style="--d:1.3s">Halo, ada kamar untuk 20–22 Juni?</div>
            <div class="cw-b cw-b-out anim" style="--d:1.9s">Masih tersedia — mau kami bantu reservasinya?</div>
          </div>
          <div class="cw-winput anim" style="--d:2.3s">
            <span>Ketik pesan…</span>
            <span class="cw-send">→</span>
          </div>
        </div>
      </div>
    </div>

    <div class="lg:order-2">
      <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Chat Widget</span>
      <h2 class="mt-3.5 text-[30px] font-extrabold leading-[1.12] tracking-[-0.025em] text-balance sm:text-[38px]">
        Ubah pengunjung website jadi percakapan
      </h2>
      <p class="mb-[30px] mt-[18px] text-[17px] leading-[1.65] text-zinc-600">
        Tempel satu potong kode di website hotel Anda dan widget chat langsung tampil. Bisa disesuaikan dengan brand,
        dibalas AI 24 jam, dan setiap pesan mengalir ke inbox GuestChat yang sama dengan kanal lainnya.
      </p>
      <div class="flex flex-col gap-4">
        {
          points.map((p) => (
            <div class="flex items-start gap-[13px]">
              <span class="flex h-[26px] w-[26px] flex-none items-center justify-center rounded-lg bg-brand-50">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                  <path d="M20 6 9 17l-5-5" stroke="var(--color-brand)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <div>
                <div class="text-[15.5px] font-bold text-zinc-900">{p.title}</div>
                <div class="mt-0.5 text-sm leading-[1.5] text-zinc-500">{p.body}</div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .mock {
    height: 420px;
    overflow: hidden;
    border-radius: 16px;
    border: 1px solid #edeff0;
    background: #fff;
    box-shadow: 0 24px 50px -30px rgba(15, 26, 12, 0.28);
  }

  .anim {
    opacity: 0;
  }
  .reveal.in-view .anim {
    animation: pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--d, 0s);
  }
  @keyframes pop {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* ===== chat widget on hotel website ===== */
  .cw-root { position: relative; }
  .cw-site {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    background: #fbfcfa;
  }
  .cw-bar {
    display: flex;
    align-items: center;
    gap: 5px;
    border-bottom: 1px solid #eef0ec;
    background: #fff;
    padding: 8px 12px;
  }
  .cw-bar .cw-dot { height: 7px; width: 7px; border-radius: 999px; background: #e2e4e0; }
  .cw-url {
    margin-left: 6px;
    border-radius: 999px;
    background: #f2f3f0;
    padding: 2px 10px;
    font-size: 9.5px;
    color: #9aa0a6;
  }
  .cw-page { flex: 1; overflow: hidden; padding: 13px 14px; }
  .cw-nav { display: flex; align-items: center; justify-content: space-between; }
  .cw-nav b { font-size: 11px; font-weight: 800; color: var(--color-brand-dark); }
  .cw-nav-links { font-size: 8.5px; color: #b6bbb2; }
  .cw-hero {
    margin-top: 12px;
    border-radius: 12px;
    border: 1px solid var(--color-brand-100);
    background: linear-gradient(135deg, var(--color-brand-50), #fff);
    padding: 14px;
  }
  .cw-hero-t {
    max-width: 58%;
    font-size: 13px;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: #1f2a17;
  }
  .cw-hero-btn {
    display: inline-block;
    margin-top: 10px;
    border-radius: 999px;
    background: var(--color-brand);
    padding: 4px 12px;
    font-size: 9.5px;
    font-weight: 700;
    color: #fff;
  }
  .cw-cards { margin-top: 12px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .cw-card { height: 44px; border-radius: 10px; border: 1px solid #eef0ec; background: #fff; }

  /* routing target — GuestChat inbox */
  .cw-inbox {
    position: absolute;
    top: 12px;
    right: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    max-width: 72%;
    border-radius: 12px;
    border: 1px solid var(--color-brand-200);
    background: #fff;
    padding: 7px 9px;
    box-shadow: 0 14px 30px -16px rgba(15, 26, 12, 0.55);
  }
  .cw-inbox-logo {
    display: flex;
    height: 24px;
    width: 24px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: var(--color-brand);
    font-size: 9px;
    font-weight: 800;
    color: #fff;
  }
  .cw-inbox-meta { min-width: 0; }
  .cw-inbox-meta b { display: block; font-size: 10.5px; color: #1f2328; }
  .cw-inbox-meta span { font-size: 9px; color: #8b9187; }
  .cw-inbox-badge {
    margin-left: auto;
    flex-shrink: 0;
    display: flex;
    height: 16px;
    min-width: 16px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--color-status-bad);
    padding: 0 4px;
    font-size: 9px;
    font-weight: 800;
    color: #fff;
  }

  /* the widget popup */
  .cw-widget {
    position: absolute;
    right: 12px;
    bottom: 12px;
    width: 210px;
    overflow: hidden;
    border-radius: 16px;
    border: 1px solid #e6e8e3;
    background: #fff;
    box-shadow: 0 26px 50px -24px rgba(15, 26, 12, 0.55);
  }
  .cw-whead {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--color-brand);
    padding: 9px 11px;
  }
  .cw-wava {
    display: flex;
    height: 26px;
    width: 26px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.22);
    font-size: 9.5px;
    font-weight: 800;
    color: #fff;
  }
  .cw-wmeta { min-width: 0; flex: 1; color: #fff; }
  .cw-wmeta b { display: block; font-size: 11.5px; line-height: 1.1; }
  .cw-wmeta span { display: flex; align-items: center; gap: 4px; font-size: 9px; color: rgba(255, 255, 255, 0.85); }
  .cw-online {
    height: 6px;
    width: 6px;
    border-radius: 999px;
    background: var(--color-brand-lime);
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.25);
  }
  .reveal.in-view .cw-online { animation: cwpulse 1.6s ease-in-out infinite; }
  @keyframes cwpulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
  .cw-wx { margin-left: auto; font-size: 14px; line-height: 1; color: rgba(255, 255, 255, 0.8); }
  .cw-wbody {
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: #f6f7f5;
    padding: 10px;
  }
  .cw-greet { font-size: 10px; color: #8b9187; }
  .cw-b {
    max-width: 86%;
    border-radius: 12px;
    padding: 6px 9px;
    font-size: 10.5px;
    line-height: 1.35;
  }
  .cw-b-in {
    align-self: flex-start;
    border-bottom-left-radius: 4px;
    border: 1px solid #ececec;
    background: #fff;
    color: #3f3f46;
  }
  .cw-b-out {
    align-self: flex-end;
    border-bottom-right-radius: 4px;
    background: var(--color-brand);
    color: #fff;
  }
  .cw-winput {
    display: flex;
    align-items: center;
    gap: 8px;
    border-top: 1px solid #eef0ec;
    background: #fff;
    padding: 8px 10px;
  }
  .cw-winput > span:first-child { flex: 1; font-size: 10px; color: #b6bbb2; }
  .cw-send {
    display: flex;
    height: 24px;
    width: 24px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--color-brand);
    font-size: 12px;
    color: #fff;
  }

  @media (prefers-reduced-motion: reduce) {
    .anim { opacity: 1 !important; animation: none !important; }
    .cw-online { animation: none !important; }
  }
</style>

<script>
  const section = document.getElementById('widget');
  if (section) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            section.classList.add('in-view');
            io.disconnect();
          }
        });
      },
      { threshold: 0.3 }
    );
    io.observe(section);
  }
</script>
