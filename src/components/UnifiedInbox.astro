---
const points = [
  {
    title: 'Satu antrean untuk semua kanal',
    body: 'Tidak perlu lompat antar aplikasi. WhatsApp, email, dan chat website mengalir ke satu daftar real-time.',
  },
  {
    title: 'Konteks tamu langsung terlihat',
    body: 'Status Upcoming, In House, atau Past Stay beserta nomor folio menempel di setiap percakapan.',
  },
  {
    title: 'Tidak ada yang terlewat',
    body: 'Indikator belum terbaca dan prioritas otomatis menjaga tiap pesan tetap tertangani.',
  },
];
---

<section id="inbox" class="reveal bg-white">
  <div class="mx-auto grid max-w-[1120px] grid-cols-1 items-center gap-14 px-5 py-[88px] sm:px-7 lg:grid-cols-2 lg:gap-[58px]">
    <div>
      <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Inbox Terpadu</span>
      <h2 class="mt-3.5 text-[30px] font-extrabold leading-[1.12] tracking-[-0.025em] text-balance sm:text-[38px]">
        Semua pesan tamu, dalam satu layar
      </h2>
      <p class="mb-[30px] mt-[18px] text-[17px] leading-[1.65] text-zinc-600">
        WhatsApp, email, dan live chat website mengalir ke satu inbox real-time. Setiap percakapan menempel pada data
        reservasi tamu — kanal asal, status menginap, hingga nomor folio — jadi staf paham konteksnya sebelum membalas.
      </p>
      <div class="flex flex-col gap-4">
        {
          points.map((p) => (
            <div class="flex items-start gap-[13px]">
              <span class="flex h-[26px] w-[26px] flex-none items-center justify-center rounded-lg bg-brand-50">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                  <path d="M20 6 9 17l-5-5" stroke="var(--color-brand)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <div>
                <div class="text-[15.5px] font-bold text-zinc-900">{p.title}</div>
                <div class="mt-0.5 text-sm leading-[1.5] text-zinc-500">{p.body}</div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- inbox mock -->
    <div>
      <div class="mock">
        <div class="mock-head">
          <span class="mock-dot"></span><span class="mock-dot"></span><span class="mock-dot"></span>
          <span class="ml-2 text-[11px] font-medium text-zinc-400">Inbox — Semua Kanal</span>
        </div>
        <div class="ib-list">
          <!-- Budi Santoso -->
          <div class="ib-row anim" style="--d:0.10s">
            <div class="ib-ava">
              <img class="ib-photo" src="https://i.pravatar.cc/96?img=12" alt="Budi Santoso" loading="lazy" />
              <span class="ib-src"><img src="/assets/logos/booking.webp" alt="Booking.com" loading="lazy" /></span>
            </div>
            <div class="ib-main">
              <div class="ib-top"><b class="ib-name">Budi Santoso</b><span class="ib-time ib-time-new">Kemarin</span></div>
              <p class="ib-prev"><span>Ini perjalanan bulan madu, kami mau kamar lantai satu ya</span></p>
              <div class="ib-tags">
                <span class="ib-tag ib-up"><svg class="ib-ic" viewBox="0 0 24 24" fill="none"><rect x="3.5" y="5" width="17" height="15" rx="2.5" stroke="currentColor" stroke-width="2" /><path d="M3.5 9.5h17M8 3v4M16 3v4" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>Upcoming<i class="ib-div"></i>Folio: 11927</span>
              </div>
            </div>
            <span class="ib-unread">2</span>
          </div>

          <!-- Siti Rahmawati -->
          <div class="ib-row anim" style="--d:0.20s">
            <div class="ib-ava">
              <img class="ib-photo" src="https://i.pravatar.cc/96?img=45" alt="Siti Rahmawati" loading="lazy" />
              <span class="ib-src"><img src="/assets/logos/traveloka.webp" alt="Traveloka" loading="lazy" /></span>
            </div>
            <div class="ib-main">
              <div class="ib-top"><b class="ib-name">Siti Rahmawati</b><span class="ib-time">Rabu</span></div>
              <p class="ib-prev"><svg class="ib-check" viewBox="0 0 24 24" fill="none"><path d="M4 12.5l5 5 11-11" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" /></svg><span>Check-in online sudah dikonfirmasi. Terima kasih!</span></p>
              <div class="ib-tags">
                <span class="ib-tag ib-inhouse"><svg class="ib-ic" viewBox="0 0 24 24" fill="none"><path d="M4 11l8-6 8 6M6 10v9h12v-9" stroke="currentColor" stroke-width="2" stroke-linejoin="round" /></svg>In House<i class="ib-div"></i>Folio: 11712</span>
              </div>
            </div>
          </div>

          <!-- Agus Setiawan -->
          <div class="ib-row anim" style="--d:0.30s">
            <div class="ib-ava">
              <img class="ib-photo" src="https://i.pravatar.cc/96?img=33" alt="Agus Setiawan" loading="lazy" />
              <span class="ib-src"><img src="/assets/logos/airbnb.webp" alt="Airbnb" loading="lazy" /></span>
            </div>
            <div class="ib-main">
              <div class="ib-top"><b class="ib-name">Agus Setiawan</b><span class="ib-time">Rabu</span></div>
              <p class="ib-prev"><svg class="ib-check" viewBox="0 0 24 24" fill="none"><path d="M4 12.5l5 5 11-11" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" /></svg><span>Halo, apakah bisa pindah ke kamar lantai bawah?</span></p>
              <div class="ib-tags">
                <span class="ib-tag ib-past"><svg class="ib-ic" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="2" /><path d="M12 7.5V12l3 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>Past Stay<i class="ib-div"></i>Folio: 11919</span>
              </div>
            </div>
          </div>

          <!-- Dewi Lestari -->
          <div class="ib-row anim" style="--d:0.40s">
            <div class="ib-ava">
              <img class="ib-photo" src="https://i.pravatar.cc/96?img=47" alt="Dewi Lestari" loading="lazy" />
              <span class="ib-src"><img src="/assets/logos/tiket.webp" alt="Tiket.com" loading="lazy" /></span>
            </div>
            <div class="ib-main">
              <div class="ib-top"><b class="ib-name">Dewi Lestari</b><span class="ib-time">Rabu</span></div>
              <p class="ib-prev"><span>Apakah bisa early check-in besok pagi?</span></p>
              <div class="ib-tags">
                <span class="ib-tag ib-up"><svg class="ib-ic" viewBox="0 0 24 24" fill="none"><rect x="3.5" y="5" width="17" height="15" rx="2.5" stroke="currentColor" stroke-width="2" /><path d="M3.5 9.5h17M8 3v4M16 3v4" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>Upcoming<i class="ib-div"></i>Folio: 11924</span>
              </div>
            </div>
          </div>

          <!-- Rizki Pratama -->
          <div class="ib-row anim" style="--d:0.50s">
            <div class="ib-ava">
              <img class="ib-photo" src="https://i.pravatar.cc/96?img=68" alt="Rizki Pratama" loading="lazy" />
              <span class="ib-src"><img src="/assets/logos/expedia.webp" alt="Expedia" loading="lazy" /></span>
            </div>
            <div class="ib-main">
              <div class="ib-top"><b class="ib-name">Rizki Pratama</b><span class="ib-time">Kemarin</span></div>
              <p class="ib-prev"><span>Terima kasih, pelayanannya sangat memuaskan!</span></p>
              <div class="ib-tags">
                <span class="ib-tag ib-inhouse"><svg class="ib-ic" viewBox="0 0 24 24" fill="none"><path d="M4 11l8-6 8 6M6 10v9h12v-9" stroke="currentColor" stroke-width="2" stroke-linejoin="round" /></svg>In House<i class="ib-div"></i>Folio: 11705</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .mock {
    height: 420px;
    overflow: hidden;
    border-radius: 16px;
    border: 1px solid #edeff0;
    background: #fff;
    box-shadow: 0 24px 50px -30px rgba(15, 26, 12, 0.28);
  }
  .mock-head {
    display: flex;
    align-items: center;
    gap: 6px;
    border-bottom: 1px solid #f1f2f0;
    padding: 10px 14px;
    background: #fbfcfa;
  }
  .mock-dot {
    height: 8px;
    width: 8px;
    border-radius: 999px;
    background: #e2e4e0;
  }

  /* entrance animation — triggered when section scrolls into view */
  .anim {
    opacity: 0;
  }
  .reveal.in-view .anim {
    animation: pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--d, 0s);
  }
  @keyframes pop {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* inbox — conversation list */
  .ib-list {
    display: flex;
    flex-direction: column;
    gap: 5px;
    height: calc(100% - 40px);
    overflow: hidden;
    padding: 8px;
    background: #f6f7f8;
  }
  .ib-row {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    border-radius: 12px;
    border: 1px solid #eceef0;
    background: #fff;
    padding: 8px 11px;
    box-shadow: 0 1px 2px rgba(15, 26, 12, 0.04);
  }
  .ib-ava {
    position: relative;
    height: 36px;
    width: 36px;
    flex-shrink: 0;
  }
  .ib-photo {
    height: 100%;
    width: 100%;
    border-radius: 10px;
    object-fit: cover;
    background: #e8eaed;
  }
  .ib-src {
    position: absolute;
    right: -5px;
    bottom: -5px;
    display: flex;
    height: 18px;
    width: 18px;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 6px;
    background: #fff;
    box-shadow: 0 0 0 2px #fff;
  }
  .ib-src img { height: 100%; width: 100%; object-fit: cover; display: block; }
  .ib-main { min-width: 0; flex: 1; }
  .ib-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
  }
  .ib-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 12.5px;
    font-weight: 700;
    color: #1f2328;
  }
  .ib-time { flex-shrink: 0; font-size: 10px; color: #a1a1aa; }
  .ib-time-new { color: var(--color-brand); font-weight: 600; }
  .ib-prev {
    margin: 2px 0 0;
    display: flex;
    align-items: center;
    gap: 4px;
    overflow: hidden;
    white-space: nowrap;
    font-size: 11px;
    color: #71767c;
  }
  .ib-prev span {
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ib-check { height: 12px; width: 12px; flex-shrink: 0; color: var(--color-brand); }
  .ib-tags { margin-top: 6px; display: flex; flex-wrap: wrap; gap: 6px; }
  .ib-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border-radius: 999px;
    border: 1px solid transparent;
    padding: 2px 8px;
    font-size: 9.5px;
    font-weight: 600;
    white-space: nowrap;
  }
  .ib-ic { height: 11px; width: 11px; flex-shrink: 0; }
  .ib-div { height: 9px; width: 1px; background: currentColor; opacity: 0.35; margin: 0 1px; }
  .ib-up { background: #fbf3d7; border-color: #f1e3b4; color: #b07d13; }
  .ib-inhouse { background: #e7f4ea; border-color: #cfe8d5; color: #2f7d3a; }
  .ib-past { background: #eef0f2; border-color: #e1e4e7; color: #697079; }
  .ib-unread {
    align-self: center;
    display: flex;
    height: 19px;
    min-width: 19px;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--color-brand);
    padding: 0 5px;
    font-size: 10px;
    font-weight: 700;
    color: #fff;
  }

  @media (prefers-reduced-motion: reduce) {
    .anim { opacity: 1 !important; animation: none !important; }
  }
</style>

<script>
  const section = document.getElementById('inbox');
  if (section) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            section.classList.add('in-view');
            io.disconnect();
          }
        });
      },
      { threshold: 0.3 }
    );
    io.observe(section);
  }
</script>
