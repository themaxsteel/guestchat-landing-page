---
const points = [
  {
    title: 'Satu antrean untuk semua kanal',
    body: 'Tidak perlu lompat antar aplikasi. WhatsApp, email, dan chat website mengalir ke satu daftar real-time.',
  },
  {
    title: 'Konteks tamu langsung terlihat',
    body: 'Status Upcoming, In House, atau Past Stay beserta nomor folio menempel di setiap percakapan.',
  },
  {
    title: 'Tidak ada yang terlewat',
    body: 'Indikator belum terbaca dan prioritas otomatis menjaga tiap pesan tetap tertangani.',
  },
];
---

<section id="inbox" class="reveal bg-white">
  <div class="mx-auto grid max-w-[1120px] grid-cols-1 items-center gap-14 px-5 py-[88px] sm:px-7 lg:grid-cols-2 lg:gap-[58px]">
    <div>
      <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Inbox Terpadu</span>
      <h2 class="mt-3.5 text-[30px] font-extrabold leading-[1.12] tracking-[-0.025em] text-balance sm:text-[38px]">
        Semua pesan tamu, dalam satu layar
      </h2>
      <p class="mb-[30px] mt-[18px] text-[17px] leading-[1.65] text-zinc-600">
        WhatsApp, email, dan live chat website mengalir ke satu inbox real-time. Setiap percakapan menempel pada data
        reservasi tamu — kanal asal, status menginap, hingga nomor folio — jadi staf paham konteksnya sebelum membalas.
      </p>
      <div class="flex flex-col gap-4">
        {
          points.map((p) => (
            <div class="flex items-start gap-[13px]">
              <span class="flex h-[26px] w-[26px] flex-none items-center justify-center rounded-lg bg-brand-50">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                  <path d="M20 6 9 17l-5-5" stroke="var(--color-brand)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <div>
                <div class="text-[15.5px] font-bold text-zinc-900">{p.title}</div>
                <div class="mt-0.5 text-sm leading-[1.5] text-zinc-500">{p.body}</div>
              </div>
            </div>
          ))
        }
      </div>

      <a
        href="/inbox"
        class="group mt-8 inline-flex items-center gap-1.5 text-[15px] font-semibold text-brand no-underline"
      >
        Selengkapnya
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="transition-transform group-hover:translate-x-0.5"
          ><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path></svg
        >
      </a>
    </div>

    <!-- inbox screenshot -->
    <div class="relative motion-safe:animate-floaty">
      <img
        src="/assets/unified-inbox.png"
        alt="Inbox terpadu GuestChat — WhatsApp, email, dan live chat dalam satu daftar percakapan"
        width="1200"
        height="900"
        loading="lazy"
        decoding="async"
        class="anim w-full"
        style="--d:0.10s"
      />
    </div>
  </div>
</section>

<style>
  /* entrance animation — triggered when section scrolls into view */
  .anim {
    opacity: 0;
  }
  .reveal.in-view .anim {
    animation: pop 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--d, 0s);
  }
  @keyframes pop {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .anim { opacity: 1 !important; animation: none !important; }
  }
</style>

<script>
  const section = document.getElementById('inbox');
  if (section) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            section.classList.add('in-view');
            io.disconnect();
          }
        });
      },
      { threshold: 0.3 }
    );
    io.observe(section);
  }
</script>
