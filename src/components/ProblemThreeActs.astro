---
// Problem section as a vertical, alternating (zigzag) timeline: one guest message
// at Villa Senja carried top-to-bottom from the tense moment, to GuestChat catching
// it, to the outcome. Each step pairs narrative text with a media slot on the
// opposite side of the centre spine — ready to hold an illustration or UI later.
const steps = [
  {
    no: '01',
    time: 'Pukul 23:47',
    title: 'Pesan masuk tengah malam',
    body: 'Andra bertanya soal kamar menghadap sawah untuk long weekend — jauh setelah tim pulang. Di dunia lama, pesan ini menunggu sampai pagi. Saat resepsionis buka HP, ia sudah booking di tempat lain.',
  },
  {
    no: '02',
    time: 'Sesaat kemudian',
    title: 'Ditangkap GuestChat',
    body: 'AI Agent langsung membalas dari data hotel Anda — ketersediaan, tarif, dan kebijakan — bukan mengarang. Kalau AI ragu, percakapan otomatis diteruskan ke staf.',
  },
  {
    no: '03',
    time: 'Pagi harinya',
    title: 'Reservasi terkonfirmasi',
    body: 'Andra memesan Kamar Sawah View untuk 18–20 Juli. Paginya, tim menemukan reservasi sudah masuk — dan tamu yang merasa diprioritaskan sejak menit pertama.',
  },
];
---

<section id="problem" class="reveal border-b border-[#f0f0f2] bg-zinc-50">
  <div class="mx-auto max-w-[1120px] px-5 py-20 sm:px-7">
    <!-- header -->
    <div class="mx-auto mb-8 max-w-[640px] text-center">
      <span class="font-mono text-xs font-medium uppercase tracking-[0.05em] text-brand">Masalahnya</span>
      <h2 class="mt-3.5 text-[28px] font-extrabold leading-[1.15] tracking-[-0.025em] text-balance sm:text-[36px]">
        Pesan tamu tak kenal jam kerja. Tim Anda kenal.
      </h2>
      <p class="mx-auto mt-3.5 max-w-[560px] text-[17px] leading-[1.6] text-zinc-600">
        Villa Senja punya 14 kamar dan tim bertiga. Ikuti satu pesan yang masuk jauh setelah mereka pulang — dan apa
        yang terjadi berikutnya.
      </p>
    </div>

    <!-- scene chip -->
    <div class="mb-12 flex justify-center">
      <span class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white px-3.5 py-1.5 text-[12.5px] font-semibold text-zinc-600">
        <span class="h-1.5 w-1.5 rounded-full bg-brand"></span>
        Villa Senja · 14 kamar · Ubud
      </span>
    </div>

    <!-- ============ vertical zigzag timeline ============ -->
    <div class="relative space-y-14 lg:space-y-20">
      <!-- centre spine (left rail on mobile) -->
      <span
        aria-hidden="true"
        class="absolute bottom-0 left-[15px] top-0 w-px -translate-x-1/2 bg-zinc-200 lg:left-1/2"
      ></span>
      <span
        aria-hidden="true"
        class="spine-fill absolute bottom-0 left-[15px] top-0 w-px bg-brand-lime shadow-[0_0_10px_1px_rgba(163,217,119,0.7)] lg:left-1/2"
      ></span>

      {
        steps.map((s, i) => {
          const textFirst = i % 2 === 0; // even steps: text left, media right
          return (
            <div class="act relative grid gap-6 pl-12 lg:grid-cols-2 lg:items-center lg:gap-16 lg:pl-0" style={`--d:${0.1 + i * 0.2}s`}>
              {/* node on the spine */}
              <span class="node absolute left-[15px] top-0 flex h-9 w-9 -translate-x-1/2 items-center justify-center rounded-full border border-zinc-200 bg-white font-mono text-[13px] font-bold text-brand shadow-sm lg:left-1/2 lg:top-1/2 lg:-translate-y-1/2">
                {s.no}
              </span>

              {/* narrative text */}
              <div class={textFirst ? 'lg:order-1 lg:pr-6 lg:text-right' : 'lg:order-2 lg:pl-6 lg:text-left'}>
                <span class="font-mono text-[11px] uppercase tracking-[0.06em] text-zinc-400">{s.time}</span>
                <h3 class="mt-2 text-[19px] font-extrabold leading-[1.2] tracking-[-0.02em] text-zinc-900 sm:text-[21px]">
                  {s.title}
                </h3>
                <p class="mt-2.5 text-[14.5px] leading-[1.6] text-zinc-600">{s.body}</p>
              </div>

              {/* media slot — minimal UI relevant to each step */}
              <div class={textFirst ? 'lg:order-2' : 'lg:order-1'}>
                <div class="rounded-2xl border border-zinc-200 bg-white p-4 shadow-[0_14px_34px_-24px_rgba(24,24,27,0.35)]">
                  {s.no === '01' && (
                    <>
                      <div class="mb-3 flex items-center gap-2">
                        <span class="flex h-5 min-w-[20px] items-center justify-center rounded-full bg-status-bad px-1.5 text-[11px] font-bold text-white">1</span>
                        <span class="text-[12px] font-semibold text-zinc-500">Belum dibaca</span>
                      </div>
                      <div class="flex justify-end">
                        <div class="max-w-[88%] rounded-2xl rounded-br-md bg-brand px-3.5 py-2.5 text-[13px] leading-[1.5] text-white">
                          Masih ada kamar untuk long weekend depan? Yang menghadap sawah.
                          <span class="mt-1 block text-right text-[10px] text-white/70">23:47</span>
                        </div>
                      </div>
                    </>
                  )}

                  {s.no === '02' && (
                    <div class="flex flex-col items-start">
                      <div class="mb-1.5 flex items-center gap-1.5">
                        <img src="/assets/logos/guestchat.webp" alt="GuestChat" width="16" height="16" class="h-4 w-4 flex-none rounded" />
                        <span class="text-[11px] font-semibold text-zinc-500">Dibalas AI Agent</span>
                      </div>
                      <div class="relative max-w-[92%] rounded-2xl rounded-bl-md bg-mist px-3.5 py-2.5 text-[13px] leading-[1.55] text-forest-900">
                        <span class="typing absolute inset-0 flex items-center justify-center gap-1.5">
                          <i></i><i></i><i></i>
                        </span>
                        <span class="ai-text">
                          Malam, Pak Andra. Kamar Sawah View tersedia 18–20 Juli, Rp1.450.000/malam termasuk sarapan. Saya
                          amankan sekarang?
                          <span class="mt-1 block text-right text-[10px] text-forest-600/70">23:47</span>
                        </span>
                      </div>
                    </div>
                  )}

                  {s.no === '03' && (
                    <div class="rounded-xl border border-brand-100 bg-brand-50/60 p-3.5">
                      <div class="flex items-center gap-2">
                        <span class="check-badge flex h-5 w-5 flex-none items-center justify-center rounded-full bg-brand text-white">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                            <path d="M20 6 9 17l-5-5" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                          </svg>
                        </span>
                        <span class="text-[13.5px] font-bold text-brand-dark">Reservasi terkonfirmasi</span>
                      </div>
                      <div class="mt-2 text-[13px] leading-[1.5] text-zinc-600">Andra · Kamar Sawah View · 18–20 Juli</div>
                    </div>
                  )}
                </div>
              </div>
            </div>
          );
        })
      }
    </div>

    <!-- closing line -->
    <p class="mx-auto mt-14 max-w-[600px] text-center text-[14.5px] leading-[1.6] text-zinc-500">
      Bekerja 24 jam di semua kanal — WhatsApp, email, dan live chat website mengalir ke satu inbox terpadu, dibantu AI
      Agent yang benar-benar paham hotel Anda.
    </p>
  </div>
</section>

<style>
  /* Steps + nodes pop in, staggered, once the section scrolls into view */
  .act,
  .node {
    opacity: 0;
  }
  #problem.in-view .act,
  #problem.in-view .node {
    animation: actPop 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: var(--d, 0s);
  }
  @keyframes actPop {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* The glowing spine fills top -> bottom */
  .spine-fill {
    transform: translateX(-50%) scaleY(0);
    transform-origin: top;
  }
  #problem.in-view .spine-fill {
    animation: spineFill 1.2s cubic-bezier(0.4, 0, 0.2, 1) both;
    animation-delay: 0.25s;
  }
  @keyframes spineFill {
    to {
      transform: translateX(-50%) scaleY(1);
    }
  }

  /* Step 2: typing dots first, then reveal the AI reply (text reserves the size) */
  .ai-text {
    opacity: 0;
  }
  #problem.in-view .ai-text {
    animation: fadeIn 0.4s ease both;
    animation-delay: 1.5s;
  }
  #problem.in-view .typing {
    animation: hideTyping 0.25s ease both;
    animation-delay: 1.5s;
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes hideTyping {
    to { opacity: 0; }
  }
  .typing i {
    display: block;
    height: 6px;
    width: 6px;
    border-radius: 999px;
    background: var(--color-forest-600);
    opacity: 0.5;
  }
  #problem.in-view .typing i {
    animation: bounce 1.2s ease-in-out infinite;
  }
  .typing i:nth-child(2) { animation-delay: 0.15s; }
  .typing i:nth-child(3) { animation-delay: 0.3s; }
  @keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.45; }
    30% { transform: translateY(-4px); opacity: 0.9; }
  }

  /* Step 3: confirmation check pops in */
  .check-badge {
    opacity: 0;
  }
  #problem.in-view .check-badge {
    animation: checkPop 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 1.1s;
  }
  @keyframes checkPop {
    from { opacity: 0; transform: scale(0.4); }
    to { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .act,
    .node,
    .ai-text,
    .check-badge {
      opacity: 1 !important;
      animation: none !important;
    }
    .spine-fill {
      transform: translateX(-50%) scaleY(1) !important;
      animation: none !important;
    }
    .typing {
      display: none !important;
    }
  }
</style>

<script>
  const section = document.getElementById('problem');
  if (section) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            section.classList.add('in-view');
            io.disconnect();
          }
        });
      },
      { threshold: 0.2 }
    );
    io.observe(section);
  }
</script>
